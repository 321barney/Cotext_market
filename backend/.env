# Context Market - Production Environment
DATABASE_URL=postgresql://context:context@localhost:5432/contextmarket
DEBUG=false
LOG_DIR=/var/log/context-market
ALLOWED_ORIGINS=

# Base / Escrow
BASE_RPC=https://mainnet.base.org
BASE_SEPOLIA_RPC=https://sepolia.base.org

# Escrow (set after deployment)
# ESCROW_CONTRACT_ADDRESS=0x...
# PLATFORM_WALLET=0x...
# ESCROW_PRIVATE_KEY=...
