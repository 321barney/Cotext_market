# Environment variables for Context Market
# Copy to .env and fill in real values

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/contextmarket

# Base / x402
BASE_RPC=https://mainnet.base.org
BASE_SEPOLIA_RPC=https://sepolia.base.org

# Escrow Contract (deployed)
ESCROW_CONTRACT_ADDRESS=0x...
PLATFORM_WALLET=0x...
ESCROW_PRIVATE_KEY=...

# OpenAI (optional, for LLM synthesis)
OPENAI_API_KEY=sk-...

# Anthropic (fallback for LLM synthesis)
ANTHROPIC_API_KEY=sk-ant-...

# App
APP_URL=http://localhost:3000
DEBUG=false

# API
API_BASE_URL=http://localhost:8000

# Logging
LOG_DIR=/root/.openclaw/workspace/innovations/context-market-v2/logs
