# ═══════════════════════════════════════════════════════════
#  Context Market - Environment Template (.env.example)
# ═══════════════════════════════════════════════════════════
#  1. Copy this file to .env:
#        cp backend/.env.example backend/.env
#  2. Replace ALL placeholder values (your_*_here) with
#     real secrets, keys, and addresses.
#  3. NEVER commit .env — it is listed in .gitignore.
# ═══════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://your_db_user_here:your_db_password_here@your_db_host_here:5432/your_db_name_here

# ── Blockchain ────────────────────────────────────────────
# Base chain RPC endpoints
BASE_RPC=https://mainnet.base.org
BASE_SEPOLIA_RPC=https://sepolia.base.org

# USDC contract on Base mainnet
USDC_CONTRACT_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# Base chain ID (8453 = mainnet, 84532 = Sepolia testnet)
BASE_CHAIN_ID=8453

# Escrow contract (deployed address — fill after running deploy script)
ESCROW_CONTRACT_ADDRESS=your_escrow_contract_address_here

# Platform wallet address (receives fees)
PLATFORM_WALLET=your_platform_wallet_address_here

# Escrow private key (server-side signing — GUARD THIS SECRET)
ESCROW_PRIVATE_KEY=your_escrow_private_key_here

# ── LLM APIs ──────────────────────────────────────────────
# OpenAI (primary LLM for synthesis)
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI model selection (gpt-4o-mini is cost-effective default)
OPENAI_MODEL=gpt-4o-mini

# Anthropic (fallback LLM for synthesis)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Anthropic model selection (claude-3-haiku is cost-effective default)
ANTHROPIC_MODEL=claude-3-haiku-20240307

# Embedding model for vector search (local, no API key needed)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── App Settings ──────────────────────────────────────────
# Public-facing URL of the frontend
APP_URL=https://yourdomain.com

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# Debug mode — MUST be "false" in production
DEBUG=false

# Directory for application logs (must be writable by the app user)
LOG_DIR=/var/log/context-market

# ── Security / Limits ─────────────────────────────────────
# Maximum queries per user per day
MAX_QUERIES_PER_DAY=20

# Dispute window in hours (users can dispute within this window)
DISPUTE_WINDOW_HOURS=24

# Platform fee in basis points (1000 = 10%)
PLATFORM_FEE_BPS=1000
